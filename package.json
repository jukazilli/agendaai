{
  "name": "agendaai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.11.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.11.0"
  },
  "scripts": {
    "build": "pnpm -r build && python -m compileall -q services/analytics-python/src",
    "clean": "pnpm -r clean",
    "dev:admin": "pnpm --dir apps/admin-web dev",
    "dev:booking": "pnpm --dir apps/booking-web dev",
    "dev:marketing": "pnpm --dir apps/marketing-site dev",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "pnpm -r lint && python -m compileall -q services/analytics-python/src"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prettier": "^3.5.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}

