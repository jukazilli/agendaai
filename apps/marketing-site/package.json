{
  "name": "@agendaai/marketing-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ./scripts/sync-brand-assets.mjs && astro build",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('.astro',{recursive:true,force:true}); fs.rmSync('public/brand',{recursive:true,force:true}); fs.rmSync('public/favicon.svg',{force:true});\"",
    "dev": "node ./scripts/sync-brand-assets.mjs && astro dev --host 127.0.0.1 --port 4173",
    "lint": "node ./scripts/sync-brand-assets.mjs && astro check"
  },
  "dependencies": {
    "astro": "^5.4.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4"
  }
}
