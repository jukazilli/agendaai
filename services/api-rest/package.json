{
  "name": "@agendaai/api-rest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "db:seed:demo": "node --import tsx scripts/seed-demo.ts",
    "dev": "node --import tsx src/index.ts",
    "lint": "tsc --project tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@agendaai/contracts": "workspace:*",
    "@agendaai/domain": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.2.1",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "tsx": "^4.20.3"
  }
}
