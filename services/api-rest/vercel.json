{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/index"
    },
    {
      "source": "/ready",
      "destination": "/api/index"
    },
    {
      "source": "/v1/:path*",
      "destination": "/api/index"
    }
  ]
}
