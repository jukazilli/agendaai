name = "agendaai-api-gateway"
main = "src/index.ts"
compatibility_date = "2026-04-02"

[vars]
PRIMARY_API_ORIGIN = "https://agendaai-eu7w.onrender.com"
SECONDARY_API_ORIGIN = "https://agendaai-api-rest.vercel.app"
